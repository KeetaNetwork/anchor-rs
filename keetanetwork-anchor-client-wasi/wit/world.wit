package keeta:anchor@0.1.0;

/// KYC-specific value types crossing the component boundary. The base
/// `coded-error` and the `account`/`certificate` primitives are reused from the
/// vendored `keeta:client` package, so every binding boundary shares one
/// account, one certificate, and one error shape.
interface types {
	/// A KYC attribute present on a certificate: its `name` (the attribute OID)
	/// and whether its value is `sensitive` (encrypted) or plain.
	record kyc-attribute {
		name: string,
		sensitive: bool,
	}

	/// An attribute to embed when issuing a leaf: its `name` (the attribute
	/// OID), whether its `value` is `sensitive` (encrypted to the subject)
	/// rather than plain, and the semantic `value` bytes.
	record issue-attribute {
		name: string,
		sensitive: bool,
		value: list<u8>,
	}

	/// A proof attesting to a sensitive attribute's committed value, validated
	/// against the certificate with only the subject's public key. `value` is the
	/// base64 attribute value the proof reveals; `salt` is its base64 commitment
	/// salt.
	record attribute-proof {
		value: string,
		salt: string,
	}

	/// The KYC operation endpoint templates a provider advertises. An absent
	/// field means the provider does not offer that operation.
	record kyc-operations {
		create-verification: option<string>,
		get-certificates: option<string>,
		get-verification-status: option<string>,
		check-locality: option<string>,
		get-estimate: option<string>,
	}

	/// A KYC provider discovered from on-chain service metadata. `country-codes`
	/// is absent for a worldwide provider.
	record kyc-provider {
		id: string,
		ca: string,
		operations: kyc-operations,
		country-codes: option<list<string>>,
	}

	/// The cost a provider expects to charge for a verification: a `token` and
	/// the `min`/`max` bounds of the charge, both decimal strings in that
	/// token's units.
	record expected-cost {
		min: string,
		max: string,
		token: string,
	}

	/// An in-progress verification: its provider `id`, the `web-url` where the
	/// user completes the flow, and the provider's `expected-cost`.
	record verification {
		id: string,
		web-url: string,
		expected-cost: expected-cost,
	}

	/// The provider-reported status of a verification (e.g. `pending`).
	record verification-status {
		status: string,
	}

	/// One issued, PEM-encoded leaf certificate together with the PEM-encoded
	/// intermediate certificates that bridge it to a trust root. The consumer
	/// parses these into `crypto` resources to verify and read claims.
	record certificate-group {
		certificate: string,
		intermediates: list<string>,
	}

	/// A verification result that the provider may report as pending: either
	/// `ready` with the value, or `retry` after the given milliseconds.
	variant verification-outcome {
		ready(verification),
		retry(u32),
	}

	/// A status result, ready or retry-after-millis.
	variant status-outcome {
		ready(verification-status),
		retry(u32),
	}

	/// A certificates result: ready with the issued groups, or retry-after-millis.
	variant certificates-outcome {
		ready(list<certificate-group>),
		retry(u32),
	}
}

/// The KYC leaf certificate: a base `keeta:client` certificate plus parsed KYC
/// attributes/claims. Built on the reused account/certificate primitives.
interface certificates {
	use keeta:client/types@0.1.0.{coded-error};
	use keeta:client/crypto@0.1.0.{account, certificate};
	use types.{kyc-attribute, issue-attribute, attribute-proof};

	/// A KYC leaf certificate.
	resource kyc-certificate {
		/// Parse a KYC certificate from its PEM encoding.
		parse: static func(pem: string) -> result<kyc-certificate, coded-error>;
		/// Issue a leaf signed by `issuer` for `subject`, embedding
		/// `attributes` (sensitive ones encrypted to the subject). `subject`
		/// and `issuer` may use different signing algorithms. `not-before` and
		/// `not-after` are Unix seconds, supplied by the caller since the
		/// component has no clock.
		issue: static func(subject: borrow<account>, issuer: borrow<account>, subject-dn: string, issuer-dn: string, serial: u64, not-before: s64, not-after: s64, is-ca: bool, attributes: list<issue-attribute>) -> result<kyc-certificate, coded-error>;
		/// The underlying base certificate.
		base: func() -> certificate;
		/// The leaf's PEM encoding.
		pem: func() -> result<string, coded-error>;
		/// Whether the leaf is valid at `unix-seconds` (Unix time).
		valid-at: func(unix-seconds: s64) -> bool;
		/// Whether the leaf chains to one of `trusted-roots` at `unix-seconds`,
		/// using `intermediates` to bridge the chain.
		verify: func(trusted-roots: list<borrow<certificate>>, intermediates: list<borrow<certificate>>, unix-seconds: s64) -> result<bool, coded-error>;
		/// The KYC attributes the leaf carries.
		attributes: func() -> list<kyc-attribute>;
		/// The plain (unencrypted) value of attribute `name`.
		plain-attribute: func(name: string) -> result<list<u8>, coded-error>;
		/// The decrypted value of sensitive attribute `name`, using `subject`'s
		/// private key.
		decrypt-attribute: func(name: string, subject: borrow<account>) -> result<list<u8>, coded-error>;
		/// A proof for sensitive attribute `name`, decrypting it with `subject`.
		/// The proof validates against this certificate without the private key.
		prove: func(name: string, subject: borrow<account>) -> result<attribute-proof, coded-error>;
		/// Whether `proof` attests to sensitive attribute `name`, validated with
		/// `subject`'s public key.
		validate-proof: func(name: string, subject: borrow<account>, proof: attribute-proof) -> result<bool, coded-error>;
	}
}

/// The KYC anchor client: discover providers, then create and track
/// verifications, signing each request with the bound account over `wasi:http`.
interface kyc {
	use keeta:client/types@0.1.0.{coded-error};
	use keeta:client/crypto@0.1.0.{account};
	use types.{
		kyc-provider,
		verification-outcome,
		status-outcome,
		certificates-outcome,
	};

	/// A KYC client bound to a signer and a metadata root.
	resource client {
		/// Build a client that resolves providers from the `root` account's
		/// on-chain service metadata, read via the node API at `node-url`, and
		/// signs each request with `signer`.
		with-account: static func(node-url: string, root: string, signer: borrow<account>) -> result<client, coded-error>;
		/// Every provider that serves all `countries` (ISO codes).
		providers: func(countries: list<string>) -> result<list<kyc-provider>, coded-error>;
		/// Begin a verification with `provider` for `countries`, optionally
		/// redirecting the user to `redirect-url` when the flow ends.
		create-verification: func(provider: kyc-provider, countries: list<string>, redirect-url: option<string>) -> result<verification-outcome, coded-error>;
		/// Fetch the certificates issued for verification `id`.
		get-certificates: func(provider: kyc-provider, id: string) -> result<certificates-outcome, coded-error>;
		/// Read the status of verification `id`.
		get-verification-status: func(provider: kyc-provider, id: string) -> result<status-outcome, coded-error>;
	}
}

/// The KYC anchor client as a WASI Preview 2 component, networked over
/// `wasi:http`, re-exporting the shared `keeta:client` `crypto` primitives
/// (accounts + base certificates) alongside anchor's KYC certificate and client.
world keeta-anchor-kyc {
	export keeta:client/crypto@0.1.0;
	export certificates;
	export kyc;
}
